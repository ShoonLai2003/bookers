<h1>Books</h1>

<table>
  <thead>   <!-- 表の見出し -->
    <tr>   <!-- 表の1行 -->
      <th>Title</th>   <!-- 見出し（boldで表示） -->
      <th>Body</th>
      <th colspan="3"></th>  <!-- Show・Edit・Destroy の3列分 -->
    </tr>
  </thead>

  <tbody>   <!-- 表のデータ部分 -->
    <% @books.each do |book| %> <!--1件ずつ取り出して繰り返す -->
      <tr>
        <td><%= book.title %></td>
        <td><%= book.body %></td>
        <td><%= link_to "Show", book %></td>
        <td><%= link_to "Edit", edit_book_path(book) %></td>
        <td>
          <%= link_to "Destroy", book_path(book),
              data: {
                turbo_method: :delete,
                turbo_confirm: "Are you sure?"
              } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>New book</h2>

<% if @book.errors.any? %>

  <div id="error_explanation">

    <h2>
      <%= @book.errors.count %> errors prohibited this book from being saved:
    </h2>

    <ul>
      <% @book.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>

  </div>

<% end %>

<%= form_with model: @book do |f| %>

  <h4>Title</h4>
  <%= f.text_field :title %>

  <h4>Body</h4>
  <%= f.text_area :body %>

  <br>

  <%= f.submit 'Create Book' %>

<% end %>